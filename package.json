{
  "name": "@claymore-dev/crucible",
  "version": "0.1.0",
  "description": "Agentic QA framework — visual verification, baseline management, and a project-agnostic MCP server that gives AI coding agents eyes.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "visual-regression",
    "agentic-qa",
    "playwright",
    "pixelmatch",
    "ai-agents",
    "claude"
  ],
  "license": "MIT",
  "author": "Dan Hannah <dan.hannah94@gmail.com>",
  "homepage": "https://github.com/danhannah94/crucible#readme",
  "bugs": {
    "url": "https://github.com/danhannah94/crucible/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danhannah94/crucible.git"
  },
  "type": "module",
  "main": "src/server.mjs",
  "bin": {
    "crucible": "./bin/crucible.mjs",
    "crucible-mcp": "./bin/crucible-mcp.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "templates/",
    "README.md",
    "DECISIONS.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node bin/crucible-mcp.mjs",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.48.0",
    "pngjs": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "vitest": "^2.1.0"
  }
}
